<!DOCTYPE html>
<html>
<head>

<title>Dragon Pearl</title>

<style>

body{
background:#000;
color:white;
text-align:center;
font-family:Arial;
}

canvas{
background:#050505;
border:3px solid #00ffff;
box-shadow:0 0 20px #00ffff;
}

#score{
font-size:22px;
margin:10px;
}

</style>
</head>

<body>

<h1>🐉 Dragon Pearl</h1>
<div id="score">Score: 0</div>

<canvas id="game" width="500" height="500"></canvas>

<script>

let canvas=document.getElementById("game")
let ctx=canvas.getContext("2d")

let grid=20

let dragon=[{x:240,y:240}]

let dx=grid
let dy=0

let score=0

let pearl={
x:Math.floor(Math.random()*25)*grid,
y:Math.floor(Math.random()*25)*grid
}

function game(){

ctx.fillStyle="black"
ctx.fillRect(0,0,500,500)

let headX=dragon[0].x+dx
let headY=dragon[0].y+dy

// wall collision
if(headX<0||headX>=500||headY<0||headY>=500){
alert("Game Over! Score: "+score)
location.reload()
}

// eat pearl
if(headX==pearl.x && headY==pearl.y){

score++
document.getElementById("score").innerText="Score: "+score

pearl={
x:Math.floor(Math.random()*25)*grid,
y:Math.floor(Math.random()*25)*grid
}

}else{

dragon.pop()

}

let newHead={x:headX,y:headY}
dragon.unshift(newHead)

// draw dragon
for(let i=0;i<dragon.length;i++){

ctx.fillStyle=i==0 ? "#00ffff" : "#009999"

ctx.fillRect(dragon[i].x,dragon[i].y,grid,grid)

}

// glowing pearl
ctx.beginPath()
ctx.arc(pearl.x+10,pearl.y+10,8,0,Math.PI*2)
ctx.fillStyle="gold"
ctx.shadowColor="gold"
ctx.shadowBlur=15
ctx.fill()
ctx.shadowBlur=0

}

document.addEventListener("keydown",function(e){

if(e.key=="ArrowUp" && dy==0){dx=0;dy=-grid}
if(e.key=="ArrowDown" && dy==0){dx=0;dy=grid}
if(e.key=="ArrowLeft" && dx==0){dx=-grid;dy=0}
if(e.key=="ArrowRight" && dx==0){dx=grid;dy=0}

})

setInterval(game,120)

</script>

</body>
</html>
